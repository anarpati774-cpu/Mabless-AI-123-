{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID" },
        "email": { "type": "string", "format": "email", "description": "The user's email address" },
        "displayName": { "type": "string", "description": "The user's display name" },
        "photoURL": { "type": "string", "description": "The user's photo URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user was created" }
      },
      "required": ["uid", "email"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A conversation between a user and the AI",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user who owns this chat" },
        "title": { "type": "string", "description": "The title of the chat" },
        "isHidden": { "type": "boolean", "description": "Whether the chat is hidden from the sidebar" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the chat was created" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "When the chat was last updated" }
      },
      "required": ["userId", "title", "isHidden", "createdAt", "updatedAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A single message in a chat",
      "type": "object",
      "properties": {
        "chatId": { "type": "string", "description": "The ID of the chat this message belongs to" },
        "userId": { "type": "string", "description": "The ID of the user who sent this message (or the AI)" },
        "role": { "type": "string", "enum": ["user", "assistant"], "description": "The role of the sender" },
        "content": { "type": "string", "description": "The text content of the message" },
        "websites": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "url": { "type": "string" },
              "description": { "type": "string" }
            }
          },
          "description": "Suggested websites for the answer"
        },
        "relatedQuestions": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Related follow-up questions"
        },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the message was sent" }
      },
      "required": ["chatId", "userId", "role", "content", "createdAt"]
    },
    "Test": {
      "title": "Test",
      "description": "A study test generated by the AI",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The user who owns this test" },
        "chatId": { "type": "string", "description": "The chat this test was generated from" },
        "title": { "type": "string", "description": "The title of the test" },
        "questions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "question": { "type": "string" },
              "options": { "type": "array", "items": { "type": "string" } },
              "correctAnswer": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the test was created" }
      },
      "required": ["userId", "title", "questions", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "User chat sessions"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a chat session"
    },
    "/tests/{testId}": {
      "schema": "Test",
      "description": "Study tests generated for the user"
    }
  }
}
